{
  "name": "github-release-notification-api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean:dist": "rimraf dist",
    "build": "pnpm clean:dist && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.8.0",
    "drizzle-orm": "^0.44.7",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "node-mocks-http": "^1.17.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
